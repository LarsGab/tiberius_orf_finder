// SLURM settings for the group's 'brain' HPC cluster.
// Intended for use as:   nextflow run nextflow/main.nf -c nextflow/conf/brain.config

process {
    executor = 'slurm'
    queue    = 'snowball,pinky,batch'
    time     = '24h'
    memory   = '8 GB'
    cpus     = 4
    beforeScript = 'eval "$(micromamba shell hook --shell bash)" && micromamba activate storm'

    withName: RUN_VARUS {
        cpus            = 24
        memory          = '24 GB'
        time            = '72h'
        errorStrategy   = 'retry'
        maxRetries      = 2
        maxForks        = 5
    }
    withName: RUN_STRINGTIE {
        cpus   = 16
        memory = '32 GB'
        time   = '24h'
    }
    withName: FETCH_ASSEMBLY {
        cpus          = 2
        memory        = '4 GB'
        time          = '4h'
        errorStrategy = 'retry'
        maxRetries    = 3
    }
    withName: LABEL_TRANSCRIPTS {
        cpus   = 2
        memory = '8 GB'
        time   = '4h'
    }
    withName: WRITE_TFRECORD {
        cpus   = 2
        memory = '60 GB'
        time   = '4h'
    }
}

executor {
    queueSize = 50
}

env {
    PYTHONPATH = '/home/gabriell/tiberius_orf_finder/src'
}

// Raw inputs and outputs intentionally live OUTSIDE the repo under:
//   /home/gabriell/tiberius_orf_finder/raw/      (read-only raw data)
//   /home/gabriell/tiberius_orf_finder/results/  (pipeline outputs)
params {
    outdir            = '/home/gabriell/tiberius_orf_finder/results'
    varus_max_batches = 1000
    chunk_len         = 9999
}
